# API key required for /convert (leave empty to disable auth — dev only)
API_KEY=

# Maximum upload size in megabytes
MAX_FILE_SIZE_MB=50

# Rate limit per IP (slowapi syntax)
RATE_LIMIT=20/minute

# Comma-separated allowed CORS origins (* = any, for dev only)
CORS_ORIGINS=*

# Set to false in production to hide /docs and /redoc
DOCS_ENABLED=true
